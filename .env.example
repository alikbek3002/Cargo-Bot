APP_NAME=Cargo Bots
ENV=development
DEBUG=true
AUTO_CREATE_DB=true
APP_ROLE=combined_web

DATABASE_URL=postgresql+asyncpg://cargo:cargo@localhost:5432/cargo
REDIS_URL=redis://localhost:6379/0

ADMIN_BOT_TOKEN=
CLIENT_BOT_TOKEN=
# Optional webhook verification tokens from Telegram.
# They protect webhook endpoints and are not related to user roles inside the bots.
ADMIN_SECRET_TOKEN=
CLIENT_SECRET_TOKEN=
# Leave empty to allow any Telegram user to use the admin bot.
ADMIN_IDS=
WEBHOOK_BASE_URL=https://example.com

STORAGE_BACKEND=local
STORAGE_BUCKET=cargo-bots
STORAGE_PREFIX=imports
LOCAL_STORAGE_PATH=./storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-east-1
AWS_S3_ENDPOINT_URL=

ADDRESS_TEMPLATE_PATH=./example_adress.txt
SUPPLIER_TEMPLATE_PATH=

SENTRY_DSN=
METRICS_ENABLED=true
BOT_MESSAGE_RATE_LIMIT_PER_SECOND=25
TASK_ALWAYS_EAGER=false
