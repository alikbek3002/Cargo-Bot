# ──────────────────────────────────────────────────────────
# Cargo Bots — ENV-файл: справочник ВСЕХ переменных
# ──────────────────────────────────────────────────────────
# Скопируйте в .env.development (для локальной разработки)
# или используйте как шпаргалку для Railway Dashboard Variables
# ──────────────────────────────────────────────────────────

# ── Основные ─────────────────────────────────────────────
APP_NAME=Cargo Bots
ENV=development                # development | staging | production
DEBUG=true
AUTO_CREATE_DB=true

# ── База данных ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cargo:cargo@localhost:5432/cargo

# ── Redis (для Celery broker и FSM storage) ──────────────
REDIS_URL=redis://localhost:6379/0

# ── Telegram боты ────────────────────────────────────────
ADMIN_BOT_TOKEN=
CLIENT_BOT_TOKEN=
# Секреты для проверки входящих webhook-запросов от Telegram.
# Не связаны с ролями пользователей.
ADMIN_SECRET_TOKEN=
CLIENT_SECRET_TOKEN=
# Telegram user ID администраторов (через запятую).
# Оставьте пустым, чтобы админ-бот был доступен любому.
ADMIN_IDS=
# Публичный URL сервиса, на который Telegram шлёт webhook.
# Для admin-web → домен admin-web, для client-web → домен client-web.
WEBHOOK_BASE_URL=https://example.com

# ── Хранилище файлов (Excel-оригиналы) ──────────────────
STORAGE_BACKEND=local          # local | s3
STORAGE_BUCKET=cargo-bots
STORAGE_PREFIX=imports
LOCAL_STORAGE_PATH=./storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-east-1
AWS_S3_ENDPOINT_URL=

# ── Шаблоны ─────────────────────────────────────────────
ADDRESS_TEMPLATE_PATH=./example_adress.txt
SUPPLIER_TEMPLATE_PATH=

# ── Мониторинг ──────────────────────────────────────────
SENTRY_DSN=
METRICS_ENABLED=true
BOT_MESSAGE_RATE_LIMIT_PER_SECOND=25
TASK_ALWAYS_EAGER=false
