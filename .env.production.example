# ──────────────────────────────────────────────────────────
# Cargo Bots — Шаблон PRODUCTION переменных для Railway
# ──────────────────────────────────────────────────────────
# НЕ заполняйте этот файл реальными значениями!
# Используйте его как перечень переменных, которые нужно
# задать через Railway Dashboard → Variables.
# ──────────────────────────────────────────────────────────

# ── Основные ─────────────────────────────────────────────
APP_NAME=Cargo Bots
ENV=production
DEBUG=false
AUTO_CREATE_DB=true

# ── База данных (Railway PostgreSQL плагин) ──────────────
DATABASE_URL=

# ── Redis (Railway Redis плагин) ─────────────────────────
REDIS_URL=

# ── Telegram боты ────────────────────────────────────────
ADMIN_BOT_TOKEN=
CLIENT_BOT_TOKEN=
ADMIN_SECRET_TOKEN=
CLIENT_SECRET_TOKEN=
ADMIN_IDS=
# Для admin-web сервиса: домен admin-web
# Для client-web сервиса: домен client-web
WEBHOOK_BASE_URL=

# ── S3-совместимое хранилище ─────────────────────────────
STORAGE_BACKEND=s3
STORAGE_BUCKET=
STORAGE_PREFIX=imports
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
AWS_S3_ENDPOINT_URL=

# ── Шаблоны (внутри контейнера) ─────────────────────────
ADDRESS_TEMPLATE_PATH=./example_adress.txt
SUPPLIER_TEMPLATE_PATH=

# ── Мониторинг ──────────────────────────────────────────
SENTRY_DSN=
METRICS_ENABLED=true
BOT_MESSAGE_RATE_LIMIT_PER_SECOND=25
TASK_ALWAYS_EAGER=false
